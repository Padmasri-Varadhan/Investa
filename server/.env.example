# Server Environment Variables - Example
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Connection String
# Local:       mongodb://127.0.0.1:27017/investa
# Atlas:       mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/investa?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/investa

# JWT Secret - use a long, random string in production
JWT_SECRET=investa_super_secret_key_2024_change_me_in_prod

NODE_ENV=development

# CORS - Frontend URL (needed in production)
# CORS_ORIGIN=https://your-app.vercel.app
